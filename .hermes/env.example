# Hermes local environment template.
# Copy to ~/.hermes/.env and fill real values there.
# Never commit real secrets.

# ============================================
# Model / Provider
# ============================================
OPENAI_API_KEY=your-openai-or-proxy-key
OPENAI_BASE_URL=https://proxy-ai.example.com/v1
OPENROUTER_API_KEY=your-openrouter-key
MODEL_NAME=gpt-5.4-mini

# ============================================
# GitHub
# ============================================
GITHUB_TOKEN=replace_me

# ============================================
# Slack Gateway
# ============================================
SLACK_BOT_TOKEN=replace_me
SLACK_APP_TOKEN=replace_me
SLACK_OWNER_USER_ID=UXXXXXXXX

# ============================================
# Notion MCP
# ============================================
NOTION_TOKEN=replace_me

# ============================================
# Jira / Atlassian MCP
# ============================================
JIRA_URL=https://blogicsystems.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=replace-me

# ============================================
# Optional custom Browser MCP
# ============================================
BROWSER_MCP_PORT=8000
